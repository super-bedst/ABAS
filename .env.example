APP_ENV=production
APP_URL=https://tkb.teamscreen.dk/Sandbox/ABAS/public
# Tidszone for visning og lagring (Danmark)
APP_TIMEZONE=Europe/Copenhagen
# Valgfri: kun nødvendig hvis auto-detektion fejler (uden ledende /)
# APP_BASE_PATH=Sandbox/ABAS/public
APP_NAME=ABA Service

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=abas
DB_USER=abas_app
DB_PASS=

TREKANT_API_URL=https://api.trekantbrand.dk
TREKANT_API_USER=
TREKANT_API_PASS=
TREKANT_TERM=ABAS

# Windows/WAMP: CA-bundle til SSL (samme som BAS Google Routes)
CURL_CAINFO=C:\wamp64\bin\Certs\Cacerts\cacert.pem

MAIL_FROM=noreply@trekantbrand.dk
MAIL_FROM_NAME=ABA Service
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
# Valgfri: tls (STARTTLS), ssl (SMTPS) — tom = auto (ssl ved port 465, ellers tls)
# SMTP_SECURE=tls

ACCESS_CONFIRM_MONTHS=3
PASSWORD_RESET_TTL_HOURS=24
WELCOME_TOKEN_TTL_HOURS=72

# SMS via BAS Api/V2/Sms/sendSms.php (BAS_SMS_API_TOKEN er påkrævet for udsendelse)
SMS_ENABLED=1
SMS_GATEWAY=bas
BAS_SMS_API_URL=https://tkb.teamscreen.dk/Sandbox/BAS
BAS_SMS_API_TOKEN=
BAS_SMS_SYSTEM=PMS
BAS_SMS_SENDER=+4541140602
SMS_INBOUND_SECRET=

# HTTP-trigger af anlægssynk (Node-RED)
SYNC_CRON_SECRET=

# HTTP-trigger af service-reconcile / testkø (Node-RED, fx hvert 30 sek)
# Tom = bruger SYNC_CRON_SECRET
SERVICE_RECONCILE_CRON_SECRET=
