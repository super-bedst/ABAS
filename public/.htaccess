RewriteEngine On
DirectorySlash Off

# SMS inbound webhook (BAS)
RewriteRule ^api/v1/sms/inbound/?$ api/v1/index.php?route=sms/inbound [QSA,L]

# Cron: anlægssynk (Node-RED / planlagt HTTP)
RewriteRule ^api/v1/cron/sync-installations/?$ api/v1/index.php?route=cron/sync-installations [QSA,L]

# Cron: service-reconcile / ekstern testkø (Node-RED)
RewriteRule ^api/v1/cron/reconcile-service/?$ api/v1/index.php?route=cron/reconcile-service [QSA,L]

# Øvrige API-ruter
RewriteRule ^api/v1/(.*)$ api/v1/index.php?route=$1 [QSA,L]

# Front controller fallback
DirectoryIndex index.php

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|svg|png|jpg|jpeg|gif|webp|ico|woff2?)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>
</IfModule>
