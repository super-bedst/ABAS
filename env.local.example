APP_ENV=production
APP_URL=https://tkb.teamscreen.dk/Sandbox/ABAS/public
# Valgfri: kun nødvendig hvis auto-detektion fejler (uden ledende /)
# APP_BASE_PATH=Sandbox/ABAS/public
APP_NAME=ABA Service

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=abas
DB_USER=abas_app
DB_PASS=

TREKANT_API_URL=https://api.trekantbrand.dk
# Brug basis-URL uden /api/v1 — det tilføjes automatisk
TREKANT_API_USER=
TREKANT_API_PASS=
TREKANT_TERM=ABAS

# Windows/WAMP: CA-bundle til SSL (samme som BAS Google Routes)
CURL_CAINFO=C:\wamp64\bin\Certs\Cacerts\cacert.pem

MAIL_FROM=noreply@trekantbrand.dk
MAIL_FROM_NAME=ABA Service
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

ACCESS_CONFIRM_MONTHS=3
PASSWORD_RESET_TTL_HOURS=24
WELCOME_TOKEN_TTL_HOURS=72

# SMS via BAS — fuld URL til send-endpoint (ingen sti tilføjes i koden)
SMS_ENABLED=1
SMS_GATEWAY=bas
BAS_SMS_API_URL=https://tkb.teamscreen.dk/Sandbox/BAS/Api/V2/Sms/sendSms.php
BAS_SMS_API_TOKEN=
BAS_SMS_SYSTEM=PMS
BAS_SMS_SENDER=+4541140602
BAS_SMS_DEDUPE_SECONDS=120
SMS_SEND_REPLIES=1

# Nøgle til HTTP-trigger af anlægssynk fra Node-RED (?key= eller Bearer)
SYNC_CRON_SECRET=

# Valgfri separat nøgle til service-reconcile (tom = bruger SYNC_CRON_SECRET)
# SERVICE_RECONCILE_CRON_SECRET=

# Aktivitetslog: slet hændelser ældre end N dage (0 eller tom = bevar alt)
ACTIVITY_LOG_RETENTION_DAYS=365

# BAS SSO (OIDC) — login fra BAS og VC Service embed i BAS
BAS_SSO_ENABLED=1
BAS_SSO_ISSUER=https://test2.beredskabsalarmering.dk/sso
BAS_SSO_CLIENT_ID=abas-web
BAS_SSO_CLIENT_SECRET=
# Valgfri: fuld URL til embed.php som BAS bruger (skal matche redirect_uri i BAS SSO-klient)
# BAS_SSO_EMBED_URL=https://teknikweb2.trekantbrand.dk/embed.php
# BAS_SSO_REDIRECT_URI=https://teknikweb2.trekantbrand.dk/sso/callback.php
# Auto-knyt BAS-bruger via e-mail hvis bas_user_links mangler (1/0)
BAS_SSO_AUTO_LINK_EMAIL=1
# Spring MFA over ved SSO-login (BAS har allerede autentificeret)
BAS_SSO_TRUST_MFA=1
# CSP frame-ancestors for iframe i BAS (standard: beredskabsalarmering + trekantbrand)
# BAS_SSO_FRAME_ANCESTORS='self' https://test2.beredskabsalarmering.dk
